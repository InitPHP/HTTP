{
    "name": "initphp/http",
    "description": "HTTP",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "InitPHP\\HTTP\\": "src/"
        },
        "files": [
            "src/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "InitPHP\\HTTP\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "Muhammet ŞAFAK",
            "email": "info@muhammetsafak.com.tr",
            "role": "Developer",
            "homepage": "https://www.muhammetsafak.com.tr"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "psr/http-message": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "php-http/psr7-integration-tests": "^1.3",
        "http-interop/http-factory-tests": "^2.2"
    }
}
